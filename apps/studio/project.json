{
  "name": "studio",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/studio",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "apps/studio"
      },
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/**/*",
        "{workspaceRoot}/packages/anvaya-core-js/pkg/**/*"
      ],
      "outputs": [
        "{projectRoot}/.next"
      ]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev",
        "cwd": "apps/studio"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next lint",
        "cwd": "apps/studio"
      }
    }
  },
  "implicitDependencies": ["@anvaya/core"]
}
